# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
checkpoints/
*.egg-info

# Virtual environments
.venv
.python-version

# IDE settings
.idea/
.vscode/

# Other files
.DS_Store
tmp
.wandb

# Model checkpoints
*.ckpt
*.pt
*.safetensors
*.sft

# Media files (Moved to LFS or specific folders)
# We remove the global ignore for *.json, *.png, etc. 
# because it blocks important project files.
# If you have large datasets or outputs, ignore them by folder:
# outputs/
# data/

# Keep specific media formats ignored ONLY if they are likely to be massive artifacts
*.heic
*.heif
*.m4a
*.mov
*.wav


# Frontend exceptions - config files and assets must be tracked
!frontend/**/*.json
!frontend/**/*.png
!frontend/**/*.jpg
!frontend/**/*.jpeg
!frontend/**/*.webp
!frontend/**/*.svg
!frontend/**/*.ico
