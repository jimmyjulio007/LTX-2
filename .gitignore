# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
checkpoints/
*.egg-info

# Virtual environments
.venv
.python-version

# IDE settings
.idea/
.vscode/

# Other files
.DS_Store
tmp
.wandb

# Model checkpoints
*.ckpt
*.pt
*.safetensors
*.sft

# Media & data files (ML training data, large assets)
*.gif
*.heic
*.heif
*.jpg
*.jpeg
*.json
*.m4a
*.mov
*.mp4
*.png
*.wav
*.webp

# Frontend exceptions - config files and assets must be tracked
!frontend/**/*.json
!frontend/**/*.png
!frontend/**/*.jpg
!frontend/**/*.jpeg
!frontend/**/*.webp
!frontend/**/*.svg
!frontend/**/*.ico
