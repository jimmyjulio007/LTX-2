# DATABASE
# URL Neon : postgresql://user:password@endpoint.neon.tech/neondb
DATABASE_URL=postgresql://user:password@endpoint.neon.tech/neondb

# RUNPOD
# Récupérez votre clé API sur https://www.runpod.io/console/user/settings
RUNPOD_API_KEY=votre_cle_api_ici
# L'ID de votre Endpoint Serverless LTX-2
RUNPOD_ENDPOINT_ID=votre_endpoint_id_ici

# SÉCURITÉ
# Clé secrète que seul Next.js et FastAPI connaissent
INTERNAL_API_SECRET=generer_une_cle_tres_longue_ici
# Token à ajouter à l'URL du webhook sur RunPod (ex: /webhook/runpod?token=...)
RUNPOD_WEBHOOK_TOKEN=autre_cle_secrete_ici
